<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<OutputType>Library</OutputType>
		<TargetFramework>net48</TargetFramework>
		<Configurations>Debug;Release</Configurations>
		<GenerateAssemblyInfo>true</GenerateAssemblyInfo>
		<WarningLevel>9999</WarningLevel>
		<LangVersion>latest</LangVersion>
		<!-- Version, AssemblyVersion and AssemblyFileVersion are automatically generated from 'manifest.json' (see ReadJsonVersion target below). -->
		<COI_MODS>$(APPDATA)\Captain of Industry\Mods</COI_MODS>

		<!-- Set to true to automatically deploy to the mods folder on build -->
		<DeployToModsFolder>true</DeployToModsFolder>
	</PropertyGroup>

	<PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Debug|AnyCPU' ">
		<DebugSymbols>true</DebugSymbols>
		<DebugType>portable</DebugType>
		<DefineConstants>DEBUG</DefineConstants>
		<OutputPath>bin\Debug\</OutputPath>
	</PropertyGroup>

	<PropertyGroup Condition="'$(Configuration)|$(Platform)' == 'Release|AnyCPU'">
		<DebugSymbols>true</DebugSymbols>
		<DebugType>portable</DebugType>
		<DefineConstants></DefineConstants>
		<Optimize>true</Optimize>
		<GenerateDocumentationFile>True</GenerateDocumentationFile>
		<OutputPath>bin\Release\</OutputPath>
	</PropertyGroup>

	<ItemGroup>
		<UpToDateCheckInput Include="manifest.json">
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
		</UpToDateCheckInput>
	</ItemGroup>

	<ItemGroup>
		<Reference Include="mscorlib">
			<HintPath>$(COI_ROOT)\Captain of Industry_Data\Managed\mscorlib.dll</HintPath>
		</Reference>
		<Reference Include="netstandard">
			<HintPath>$(COI_ROOT)\Captain of Industry_Data\Managed\netstandard.dll</HintPath>
		</Reference>
		<Reference Include="System">
			<HintPath>$(COI_ROOT)\Captain of Industry_Data\Managed\System.dll</HintPath>
		</Reference>
		<Reference Include="System.Core">
			<HintPath>$(COI_ROOT)\Captain of Industry_Data\Managed\System.Core.dll</HintPath>
		</Reference>
		<Reference Include="Mafi">
			<HintPath>$(COI_ROOT)\Captain of Industry_Data\Managed\Mafi.dll</HintPath>
		</Reference>
		<Reference Include="Mafi.Core">
			<HintPath>$(COI_ROOT)\Captain of Industry_Data\Managed\Mafi.Core.dll</HintPath>
		</Reference>
		<Reference Include="Mafi.Base">
			<HintPath>$(COI_ROOT)\Captain of Industry_Data\Managed\Mafi.Base.dll</HintPath>
		</Reference>
		<Reference Include="Mafi.Unity">
			<HintPath>$(COI_ROOT)\Captain of Industry_Data\Managed\Mafi.Unity.dll</HintPath>
		</Reference>
		<Reference Include="UnityEngine.CoreModule">
			<HintPath>$(COI_ROOT)\Captain of Industry_Data\Managed\UnityEngine.CoreModule.dll</HintPath>
		</Reference>
		<Reference Include="UnityEngine.UIElementsModule">
			<HintPath>$(COI_ROOT)\Captain of Industry_Data\Managed\UnityEngine.UIElementsModule.dll</HintPath>
		</Reference>
		<Reference Include="UnityEngine.AudioModule">
			<HintPath>$(COI_ROOT)\Captain of Industry_Data\Managed\UnityEngine.AudioModule.dll</HintPath>
		</Reference>
	</ItemGroup>

	<Target Name="CheckCoiRoot" BeforeTargets="ResolveAssemblyReferences">
		<Error Condition="'$(COI_ROOT)' == ''" Text="Environment variable 'COI_ROOT' is not set. Set it to your Captain of Industry install directory." />
	</Target>

	<!-- Version generator: reads manifest.json and sets assembly version metadata. -->
	<UsingTask TaskName="ProcessManifest" TaskFactory="RoslynCodeTaskFactory" AssemblyFile="$(MSBuildToolsPath)\Microsoft.Build.Tasks.Core.dll">

		<ParameterGroup>
			<Manifest ParameterType="System.String" Required="true" />
			<DefaultTitle ParameterType="System.String" Required="true" />
			<NormalizedVersion Output="true" ParameterType="System.String" />
			<ManifestVersion Output="true" ParameterType="System.String" />
			<AuthorName Output="true" ParameterType="System.String" />
			<DisplayTitle Output="true" ParameterType="System.String" />
		</ParameterGroup>

		<Task>
			<Using Namespace="System.IO" />
			<Using Namespace="System.Text.RegularExpressions" />

			<Code Type="Fragment" Language="cs">
				<![CDATA[
					string json;
					try {
						json = File.ReadAllText(Manifest);
					}
					catch (Exception ex)
					{
						Log.LogError("Failed to read manifest.json: " + ex.Message);
						NormalizedVersion = "0.0.0.0";
						ManifestVersion = "0.0.0";
						AuthorName = "Unknown";
						DisplayTitle = DefaultTitle;
						return false;
					}

					// Parse "version": "X.Y.Z[a]" with regex.
					var versionMatch = Regex.Match(json, "\"version\"\\s*:\\s*\"([^\"]+)\"");
					ManifestVersion = versionMatch.Success ? versionMatch.Groups[1].Value : "0.0.0";

					// Normalize to four-part assembly version. Letter suffix (a..z) becomes revision number 1..26.
					var verMatch = Regex.Match(ManifestVersion, @"^(\d+)\.(\d+)(\.(\d+)([a-z]?))?$");
					if (verMatch.Success)
					{
						var major = verMatch.Groups[1].Value;
						var minor = verMatch.Groups[2].Value;
						var patch = verMatch.Groups[4].Success ? verMatch.Groups[4].Value : "0";
						var suffix = verMatch.Groups[5].Value;
						int revision = string.IsNullOrEmpty(suffix) ? 0 : (char.ToLower(suffix[0]) - 'a' + 1);
						NormalizedVersion = major + "." + minor + "." + patch + "." + revision;
					}
					else
					{
						Log.LogError("Invalid version format in manifest.json: " + ManifestVersion);
						NormalizedVersion = "0.0.0.0";
					}

					// Parse "authors": [ "X", "Y" ].
					var authorsBlockMatch = Regex.Match(json, "\"authors\"\\s*:\\s*\\[([^\\]]*)\\]");
					if (authorsBlockMatch.Success)
					{
						var names = Regex.Matches(authorsBlockMatch.Groups[1].Value, "\"([^\"]+)\"");
						var list = new System.Collections.Generic.List<string>();
						foreach (Match m in names) list.Add(m.Groups[1].Value);
						AuthorName = list.Count > 0 ? string.Join(", ", list.ToArray()) : "Unknown";
					}
					else
					{
						AuthorName = "Unknown";
					}

					var displayMatch = Regex.Match(json, "\"display_name\"\\s*:\\s*\"([^\"]+)\"");
					DisplayTitle = displayMatch.Success ? displayMatch.Groups[1].Value : DefaultTitle;
				]]>
			</Code>
		</Task>
	</UsingTask>

	<Target Name="ReadJsonVersion" BeforeTargets="GetAssemblyVersion">
		<Error Condition="'$(COI_ROOT)' == ''" Text="Environment or project variable 'COI_ROOT' is not set." />
		<Error Condition="'$(COI_MODS)' == ''" Text="Environment or project variable 'COI_MODS' is not set." />

		<ProcessManifest Manifest="manifest.json" DefaultTitle="$(TargetName)">
			<Output TaskParameter="NormalizedVersion" PropertyName="VersionNormalized" />
			<Output TaskParameter="AuthorName" PropertyName="AuthorName" />
			<Output TaskParameter="DisplayTitle" PropertyName="DisplayTitle" />
			<Output TaskParameter="ManifestVersion" PropertyName="ManifestVersion" />
		</ProcessManifest>

		<PropertyGroup>
			<Version>$(VersionNormalized)</Version>
			<FileVersion>$(VersionNormalized)</FileVersion>
			<AssemblyVersion>$(VersionNormalized)</AssemblyVersion>
			<AssemblyTitle>$(DisplayTitle)</AssemblyTitle>
			<Product>$(DisplayTitle)</Product>
			<Company>$(AuthorName)</Company>
			<Copyright>$(AuthorName)</Copyright>
		</PropertyGroup>
	</Target>

	<!-- Deploy to mods folder on build -->
	<Target Name="DeployToModsFolder" AfterTargets="PostBuildEvent" Condition=" '$(DeployToModsFolder)' == 'true' AND '$(ProjectDir)' != '*Undefined*' ">
		<Copy SourceFiles="$(ProjectDir)\manifest.json" DestinationFolder="$(COI_MODS)\$(TargetName)\" />
		<Copy SourceFiles="$(TargetPath)" DestinationFolder="$(COI_MODS)\$(TargetName)\" />
		<Copy SourceFiles="$(TargetDir)$(TargetName).pdb" DestinationFolder="$(COI_MODS)\$(TargetName)\" Condition="'$(Configuration)' == 'Debug'" />
	</Target>
</Project>
